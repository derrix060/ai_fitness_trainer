# Required — Claude Code auth
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...  # from `claude setup-token`

# Required — Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...       # from @BotFather
ALLOWED_TELEGRAM_USER_IDS=123456789        # comma-separated Telegram user IDs

# Required — Intervals.icu
INTERVALS_API_KEY=...                       # from intervals.icu Settings > Developer
INTERVALS_ATHLETE_ID=i12345                 # your athlete ID

# Optional
CLAUDE_MODEL=sonnet                         # default model (sonnet/opus/haiku)
CLAUDE_TIMEOUT=120                          # seconds before subprocess timeout
LOG_LEVEL=INFO
